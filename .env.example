# Copy to .env and fill in. Never commit your real .env.

# REQUIRED. Long random string used to encrypt the Verkada API key at rest.
# Generate one with:  openssl rand -base64 32
MASTER_KEY=

# OPTIONAL. If set, seeds the admin password on first boot. Otherwise you set
# the admin password in the browser on first visit.
ADMIN_PASSWORD=

# OPTIONAL. Set to 1 when running behind an HTTPS reverse proxy so secure
# cookies are issued correctly.
TRUST_PROXY=0

# OPTIONAL. Override for non-US Verkada regions, e.g. https://api.eu.verkada.com
VERKADA_BASE_URL=https://api.verkada.com

# OPTIONAL. Host port to expose the app on (container always listens on 8080).
APP_PORT=8080
